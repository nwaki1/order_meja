DATABASE_URL=postgres://sportiva:sportiva@localhost:5432/sportiva
PORT=3001
RUST_LOG=sportiva_backend=debug,tower_http=debug

# Optional: auto-create an admin user on startup (only if email is set).
BOOTSTRAP_ADMIN_EMAIL=admin@sportiva.local
BOOTSTRAP_ADMIN_PASSWORD=change-me
BOOTSTRAP_ADMIN_UPDATE_PASSWORD=false

# Password reset
PASSWORD_RESET_BASE_URL=http://localhost:3000

# SMTP (optional). If SMTP_HOST is empty, emails are logged only.
SMTP_HOST=
SMTP_USERNAME=
SMTP_PASSWORD=
SMTP_FROM=Sportiva <no-reply@sportiva.local>
